{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All C++ Files (Windows)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}/Order_structures/*.cpp",
                "${workspaceFolder}/Simulator_structures/*.cpp",
                "${workspaceFolder}/Trade_logic/*.cpp",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild", //To change when debugging
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/Order_structures/*.cpp",
                "${workspaceFolder}/Simulator_structures/*.cpp",
                "${workspaceFolder}/Trade_logic/*.cpp",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Build All C++ Files (clang)",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}/Order_structures/*.cpp",
                "${workspaceFolder}/Simulator_structures/*.cpp",
                "${workspaceFolder}/Trade_logic/*.cpp",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/main"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}